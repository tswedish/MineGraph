# Multi-stage build for the Extremal web app.
# Builds SvelteKit static site, serves via nginx with API proxy.

FROM node:24-slim AS builder

ARG BUILD_COMMIT=unknown

WORKDIR /app
COPY package.json package-lock.json ./
COPY packages/ packages/
COPY web/ web/
COPY dashboard/ dashboard/
RUN npm install
RUN BUILD_COMMIT=${BUILD_COMMIT} npm run build --workspace=web

FROM nginx:alpine
RUN apk add --no-cache gettext
COPY --from=builder /app/web/build /usr/share/nginx/html
COPY deploy/nginx-web.conf /etc/nginx/conf.d/default.conf.template
COPY deploy/web-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

EXPOSE 8080
ENTRYPOINT ["/docker-entrypoint.sh"]
