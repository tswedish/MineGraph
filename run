#!/usr/bin/env bash
# Extremal v1 task runner
set -euo pipefail
cd "$(dirname "$0")"

RELEASE=""
EXTRA_ARGS=()

# Extract --release flag
for arg in "$@"; do
    if [[ "$arg" == "--release" ]]; then
        RELEASE="--release"
    fi
done

cmd="${1:-help}"
shift || true

# Remove --release from remaining args
for arg in "$@"; do
    if [[ "$arg" != "--release" ]]; then
        EXTRA_ARGS+=("$arg")
    fi
done

case "$cmd" in
    ci)
        echo "=== cargo fmt ==="
        cargo fmt --check
        echo "=== cargo clippy ==="
        cargo clippy --all-targets -- -D warnings
        echo "=== cargo test ==="
        cargo test
        echo "=== CI passed ==="
        ;;
    build)
        cargo build $RELEASE "${EXTRA_ARGS[@]}"
        ;;
    test)
        cargo test $RELEASE "${EXTRA_ARGS[@]}"
        ;;
    clippy)
        cargo clippy --all-targets -- -D warnings
        ;;
    fmt)
        cargo fmt
        ;;
    server)
        cargo run $RELEASE -p extremal-server -- "${EXTRA_ARGS[@]}"
        ;;
    worker)
        cargo run $RELEASE -p extremal-worker -- "${EXTRA_ARGS[@]}"
        ;;
    cli)
        cargo run $RELEASE -p extremal-cli -- "${EXTRA_ARGS[@]}"
        ;;
    web-dev)
        cd web && npm run dev
        ;;
    web-build)
        cd web && npm run build
        ;;
    web-check)
        cd web && npm run check
        ;;
    dashboard)
        cargo run $RELEASE -p extremal-dashboard -- "${EXTRA_ARGS[@]}"
        ;;
    dashboard-ui)
        cd dashboard && npm run dev
        ;;
    fleet)
        ./scripts/fleet.sh "${EXTRA_ARGS[@]}" $RELEASE
        ;;
    stop-fleet)
        echo "Killing all extremal-worker processes..."
        pkill -f "extremal-worker" 2>/dev/null || true
        sleep 1
        if pgrep -f "extremal-worker" > /dev/null 2>&1; then
            echo "Force killing remaining..."
            pkill -9 -f "extremal-worker" 2>/dev/null || true
        fi
        echo "Done."
        ;;
    agent-loop)
        ./scripts/loop.sh "${EXTRA_ARGS[@]}"
        ;;
    agent-orchestrate)
        ./scripts/orchestrator.sh "${EXTRA_ARGS[@]}"
        ;;
    agent-fleet)
        ./scripts/agent-fleet.sh "${EXTRA_ARGS[@]}"
        ;;
    agent-status)
        ./scripts/agent-status.sh "${EXTRA_ARGS[@]}"
        ;;
    agent-snapshot)
        ./scripts/agent-snapshot.sh "${EXTRA_ARGS[@]}"
        ;;
    migrate)
        cargo run -p extremal-server -- --migrate
        ;;
    help|*)
        cat <<EOF
Extremal v1 task runner

Usage: ./run <command> [--release] [args...]

Commands:
  ci          Full CI: fmt + clippy + test
  build       Build all crates
  test        Run tests
  clippy      Run clippy
  fmt         Format code
  server      Start API server
  worker      Start search worker
  cli         Run extremal CLI
  dashboard   Start dashboard relay server on :4000
  dashboard-ui Dashboard SvelteKit dev server on :5174
  web-dev     SvelteKit dev server on :5173
  web-build   Build web app for production
  fleet       Launch worker fleet (--workers N --n N --dashboard URL)
  stop-fleet  Kill all running workers
  agent-orchestrate  Meta-agent: auto-alternate research + experiments
  agent-loop  Autonomous experiment loop (--workers N --polish N --interval 5m)
  agent-fleet Launch experiment agent fleet (--workers N --n N --polish N)
  agent-status  Fleet status report (agent-status [LOG_DIR])
  agent-snapshot  Take leaderboard snapshot (agent-snapshot [N] [SERVER])
  migrate     Run database migrations
  help        Show this help

Add --release for optimized builds.
EOF
        ;;
esac
