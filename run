#!/usr/bin/env bash
# RamseyNet dev runner
#
# Usage: ./run <command> [--release] [options...]
#
# Commands:
#   ci         Full CI: clippy + tests + web build
#   test       cargo test --all
#   clippy     cargo clippy --all-targets
#   build      cargo build --all
#   web        pnpm install && pnpm build (in web/)
#   web-dev    pnpm dev (live reload on :5173)
#   server     API server on :3001
#   server-log API server with file logging (logs/)
#   search     Search worker (--k, --ell, --n for auto-start; omit for idle mode)
#   bench      Criterion benchmarks for verifier/scoring
#   seed       Seed DB with test graphs
#   experiment Head-to-head strategy experiment (--a tree --b tree2)
#   fleet      Launch N workers (--workers 16 --strategy tree2)
#
# Add --release to build/server/search for optimized (5-20x faster) builds.

bash "$(dirname "$0")/scripts/wsl-dev.sh" "$@"
