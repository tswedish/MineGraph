# MineGraph Server Configuration
# Copy to .env and adjust values as needed.

# PostgreSQL connection URL
DATABASE_URL=postgres://minegraph:minegraph@localhost/minegraph

# Server port
PORT=3001

# Maximum leaderboard entries per n value
LEADERBOARD_CAPACITY=500

# Maximum k for clique histogram scoring
MAX_K=5

# Maximum allowed graph vertex count (graph6 limit: 62)
MAX_N=62

# Maximum database connections in the pool
DB_MAX_CONNECTIONS=10

# Path to server Ed25519 signing key (optional; generates ephemeral key if unset)
# SERVER_KEY_PATH=.config/minegraph/server-key.json

# Allowed CORS origins (comma-separated; if unset, allows all origins)
# ALLOWED_ORIGINS=https://minegraph.app,https://www.minegraph.app

# Logging level
RUST_LOG=info
